---
import { Image } from "astro:assets";
import coverWebDay2026 from "../img/webday_1.svg";
import kudos from "../img/webday_2.svg";
---

<p-slide class="cover">
  <Image src={coverWebDay2026} alt="Web Day 2026 Cover" />
</p-slide>
<p-slide class="cover">
  <Image src={kudos} alt="Web Day 2026 Kudos" />
</p-slide>

<style>
  img {
    width: 100vw;
    height: 100vh;
    object-fit: fill;
  }
</style>
